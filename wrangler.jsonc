{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "scare-the-spire",
  "main": "workers/main-worker.ts",
  "minify": true,
  "compatibility_date": "2026-06-15",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "PATCH_WORKER",
      "service": "scare-the-spire-patches"
    }
  ],
  "env": {
    "phase4": {
      "workers_dev": true,
      "preview_urls": true,
      "services": [
        {
          "binding": "PATCH_WORKER",
          "service": "scare-the-spire-patches-phase4"
        }
      ]
    }
  },
  "observability": {
    "enabled": true
  }
}
