{
  "name": "scare-the-spire",
  "version": "0.1.0",
  "packageManager": "pnpm@10.21.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/ensure-comment-entities.mjs && node scripts/dev-patch-proxy.mjs",
    "dev:next": "node scripts/ensure-comment-entities.mjs && next dev",
    "dev:mobile": "node scripts/mobile-qa.mjs",
    "qa:mobile": "node scripts/mobile-qa.mjs",
    "static:data": "tsx scripts/generate-static-api-data.ts",
    "build": "pnpm static:data && next build && tsx scripts/prune-dev-route-traces.ts && tsx scripts/check-vercel-function-traces.ts",
    "cf:build": "pnpm static:data && opennextjs-cloudflare build && node scripts/copy-cf-static-pages.mjs",
    "cf:size": "node scripts/check-cloudflare-worker-size.mjs",
    "cf:preview": "pnpm static:data && NEXT_PUBLIC_ENABLE_DEV_TOOLS=1 opennextjs-cloudflare build && node scripts/copy-cf-static-pages.mjs && opennextjs-cloudflare preview",
    "cf:deploy:built": "opennextjs-cloudflare deploy -- --keep-vars",
    "cf:deploy": "pnpm cf:build && pnpm cf:size && pnpm cf:deploy:built",
    "cf:upload:built": "opennextjs-cloudflare upload -- --keep-vars",
    "cf:upload": "pnpm cf:build && pnpm cf:size && pnpm cf:upload:built",
    "cf:patch:deploy": "NEXT_PUBLIC_SUPABASE_ENV=production pnpm patch:build && wrangler deploy --config wrangler.patch.jsonc --keep-vars",
    "cf:patch:preview": "pnpm patch:build && wrangler dev --config wrangler.patch.jsonc --local",
    "cf:typegen": "wrangler types",
    "patch:build": "rm -rf .patch-worker && mkdir -p .patch-worker/assets/_patches && pnpm patch:css && pnpm patch:html && pnpm patch:assets",
    "patch:css": "tailwindcss -i src/app/globals.css -o .patch-worker/assets/_patches/patch.css --minify",
    "patch:assets": "node scripts/copy-patch-worker-assets.mjs",
    "patch:dev": "pnpm cf:patch:preview",
    "patch:html": "tsx scripts/build-patch-worker.tsx",
    "patch:test": "tsx scripts/check-patch-pending-links.tsx",
    "start": "next start",
    "lint": "eslint",
    "test:visual": "playwright test scripts/visual-check.spec.ts",
    "og:status": "tsx scripts/report-og-images.ts",
    "codex:diff": "tsx scripts/generate-entity-diffs.ts",
    "codex:validate": "tsx scripts/validate-entity-versions.ts",
    "codex:validate-references": "tsx scripts/validate-codex-references.ts",
    "sts2:patch-lines": "tsx scripts/generate-sts2-patch-lines.ts",
    "sts2:index-images": "node scripts/build-sts2-public-image-file-index.mjs",
    "sts2:render-encounters": "node scripts/render-sts2-encounter-spine-portraits.mjs",
    "sts2:render-monsters": "node scripts/render-sts2-monster-spine-portraits.mjs",
    "sts2:extract-event-vfx": "uv run --with pillow --with texture2ddecoder python scripts/extract-event-vfx-scenes.py",
    "i18n:sync": "PYTHONDONTWRITEBYTECODE=1 python3 scripts/sync-game-localization.py",
    "i18n:validate": "PYTHONDONTWRITEBYTECODE=1 python3 scripts/validate-i18n.py",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@esotericsoftware/spine-player": "4.2.115",
    "@supabase/supabase-js": "^2.98.0",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-character-count": "^3.22.3",
    "@tiptap/extension-mention": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/suggestion": "^3.22.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "es-hangul": "^2.3.8",
    "lucide-react": "^0.575.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@next/env": "16.2.6",
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wrangler": "^4.100.0"
  }
}
