{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "scare-the-spire-patches",
  "main": "workers/patch-worker.ts",
  "minify": true,
  "compatibility_date": "2026-06-15",
  "assets": {
    "directory": ".patch-worker/assets",
    "binding": "ASSETS",
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "none"
  },
  "observability": {
    "enabled": true
  }
}
